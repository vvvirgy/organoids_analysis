require(tidyverse)
df = readxl::read_xls("~/Downloads/SupplementalTable05.xls")
# Convert Chr to factor and define chromosome sizes (based on hg38 as example, or adjust)
chr_sizes <- data.frame(
Chr = as.character(c(1:22)),
chr_length = c(
248956422, 242193529, 198295559, 190214555, 181538259, 170805979,
159345973, 145138636, 138394717, 133797422, 135086622, 133275309,
114364328, 107043718, 101991189, 90338345, 83257441, 80373285,
58617616, 64444167, 46709983, 50818468)
)
# Add chromosomes in your data that are missing from chr_sizes
chr_sizes <- chr_sizes %>%
filter(Chr %in% df$Chr)
# Compute cumulative start for each chromosome
chr_sizes <- chr_sizes %>%
arrange(as.numeric(Chr)) %>%
mutate(chr_start = cumsum(lag(chr_length, default = 0)))
# Merge to get cumulative start
df <- df %>%
left_join(chr_sizes, by = "Chr") %>%
mutate(
genome_start = Start + chr_start,
genome_stop = Stop + chr_start
)
# Plot
ggplot(df) +
geom_rect(
aes(xmin = genome_start, xmax = genome_stop,
ymin = 2, ymax = `Mean CN`, fill = `CN Status`),
data = df %>% filter(`Mean CN` >= 2),
alpha = 0.6
) +
geom_rect(
aes(xmin = genome_start, xmax = genome_stop,
ymin = `Mean CN`, ymax = 2, fill = `CN Status`),
data = df %>% filter(`Mean CN` < 2),
alpha = 0.6
) +
scale_fill_manual(values = c("gain" = "red", "loss" = "blue")) +
geom_hline(yintercept = 2, linetype = "dashed") +
labs(
x = "Genomic position",
y = "Copy Number",
title = "Genome-wide Copy Number Profile",
fill = "CN Status"
) +
theme_minimal()
df
require(tidyverse)
df = readxl::read_xls("~/Downloads/SupplementalTable05.xls")
# Convert Chr to factor and define chromosome sizes (based on hg38 as example, or adjust)
chr_sizes <- data.frame(
Chr = as.character(c(1:22)),
chr_length = c(
248956422, 242193529, 198295559, 190214555, 181538259, 170805979,
159345973, 145138636, 138394717, 133797422, 135086622, 133275309,
114364328, 107043718, 101991189, 90338345, 83257441, 80373285,
58617616, 64444167, 46709983, 50818468)
)
# Compute cumulative chr start
chr_sizes <- chr_sizes %>%
arrange(as.numeric(Chr)) %>%
mutate(chr_start = cumsum(lag(chr_length, default = 0)))
# Add genome coordinates
df <- df %>%
left_join(chr_sizes, by = "Chr") %>%
mutate(genome_start = Start + chr_start,
genome_stop = Stop + chr_start)
# Bin genome (e.g., 1Mb bins)
bin_size <- 1e6
# Create bin-wise data
bins <- tibble(pos = seq(0, max(df$genome_stop), by = bin_size)) %>%
mutate(bin_start = pos,
bin_end = pos + bin_size,
bin_mid = (bin_start + bin_end)/2)
df
require(tidyverse)
df = readxl::read_xls("~/Downloads/SupplementalTable05.xls")
# Convert Chr to factor and define chromosome sizes (based on hg38 as example, or adjust)
chr_sizes <- data.frame(
Chr = as.character(c(1:22)),
chr_length = c(
248956422, 242193529, 198295559, 190214555, 181538259, 170805979,
159345973, 145138636, 138394717, 133797422, 135086622, 133275309,
114364328, 107043718, 101991189, 90338345, 83257441, 80373285,
58617616, 64444167, 46709983, 50818468)
)
# Compute cumulative chr start
chr_sizes <- chr_sizes %>%
arrange(as.numeric(Chr)) %>%
mutate(chr_start = cumsum(lag(chr_length, default = 0)))
chr_sizes
df %>%
left_join(chr_sizes, by = "Chr") %>%
mutate(genome_start = Start + chr_start,
genome_stop = Stop + chr_start)
# Add genome coordinates
df <- df %>%
left_join(chr_sizes, by = "Chr") %>%
mutate(genome_start = Start + chr_start,
genome_stop = Stop + chr_start)
# Bin genome (e.g., 1Mb bins)
bin_size <- 1e6
tibble(pos = seq(0, max(df$genome_stop), by = bin_size)) %>%
mutate(bin_start = pos,
bin_end = pos + bin_size,
bin_mid = (bin_start + bin_end)/2)
df$genome_stop
max(df$genome_stop)
# Create bin-wise data
bins <- tibble(pos = seq(0, max(df$genome_stop, na.rm = T), by = bin_size)) %>%
mutate(bin_start = pos,
bin_end = pos + bin_size,
bin_mid = (bin_start + bin_end)/2)
# Expand each CN segment into all bins it spans
df_bins <- df %>%
rowwise() %>%
mutate(bins_covered = list(bins$bin_start[
(genome_start < bins$bin_end) & (genome_stop > bins$bin_start)
])) %>%
unnest(bins_covered) %>%
mutate(bin = bins_covered) %>%
select(Sample, bin, `CN Status`)
df_bins
# Count gain/loss per bin
summary_counts <- df_bins %>%
group_by(bin, `CN Status`) %>%
summarise(n = n(), .groups = "drop") %>%
pivot_wider(names_from = `CN Status`, values_from = n, values_fill = 0) %>%
mutate(net = gain - loss,
gain = gain,
loss = -loss)  # Make loss negative for plotting
# Plot
ggplot(summary_counts, aes(x = bin)) +
geom_col(aes(y = gain), fill = "red", alpha = 0.7) +
geom_col(aes(y = loss), fill = "blue", alpha = 0.7) +
labs(x = "Genomic position (binned)", y = "# Segments",
title = "Genome-wide Distribution of CN Gains and Losses") +
theme_minimal()
summary_counts
require(tidyverse)
df = readxl::read_xls("~/Downloads/SupplementalTable05.xls")
# Convert Chr to factor and define chromosome sizes (based on hg38 as example, or adjust)
chr_sizes <- data.frame(
Chr = as.character(c(1:22)),
chr_length = c(
248956422, 242193529, 198295559, 190214555, 181538259, 170805979,
159345973, 145138636, 138394717, 133797422, 135086622, 133275309,
114364328, 107043718, 101991189, 90338345, 83257441, 80373285,
58617616, 64444167, 46709983, 50818468)
)
# Define bin size
bin_size <- 1e6
# Generate chromosome-wise bins
bins <- chr_sizes %>%
rowwise() %>%
mutate(bin_starts = list(seq(0, chr_length, by = bin_size))) %>%
unnest(bin_starts) %>%
mutate(
bin_start = bin_starts,
bin_end = bin_start + bin_size,
bin_mid = bin_start + bin_size / 2
) %>%
select(Chr, bin_start, bin_end, bin_mid)
# Expand each CN segment to all overlapping bins
df_bins <- df %>%
inner_join(bins, by = "Chr") %>%
filter(Start < bin_end & Stop > bin_start) %>%
mutate(bin = bin_start)
# Count gain/loss per bin per chromosome
summary_counts <- df_bins %>%
group_by(Chr, bin, `CN Status`) %>%
summarise(n = n(), .groups = "drop") %>%
pivot_wider(names_from = `CN Status`, values_from = n, values_fill = 0) %>%
mutate(
gain = ifelse(!is.na(gain), gain, 0),
loss = ifelse(!is.na(loss), -loss, 0)  # negative for plotting
)
# Plot faceted by chromosome
ggplot(summary_counts, aes(x = bin)) +
geom_col(aes(y = gain), fill = "red", alpha = 0.7) +
geom_col(aes(y = loss), fill = "blue", alpha = 0.7) +
facet_wrap(~Chr, scales = "free_x") +
labs(
x = "Position along chromosome",
y = "# Segments",
title = "CN Gain/Loss Frequency per Bin (Faceted by Chromosome)"
) +
theme_minimal() +
theme(strip.text = element_text(face = "bold"))
